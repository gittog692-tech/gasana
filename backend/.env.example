# ─────────────────────────────────────────────────────────────────
# KTU AI Platform – Environment Variables Template
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real API keys.
# The .env file is gitignored and will never be committed.
# ─────────────────────────────────────────────────────────────────

# Google AI Studio (Gemini) — get your key at https://aistudio.google.com
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# OpenRouter (optional fallback) — https://openrouter.ai
OPENROUTER_API_KEY=

# Groq (optional fallback) — https://console.groq.com
GROQ_API_KEY=

# YouTube Data API (optional) — https://console.cloud.google.com
YOUTUBE_API_KEY=

# App settings
DEBUG=true
